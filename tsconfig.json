{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "outDir": "dist",
        "types": ["jest"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
