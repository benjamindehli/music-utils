{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "outDir": "dist",
        "rootDir": "./src",
        "ignoreDeprecations": "6.0" // Temporary workaround until tsup supports TypeScript 6.0
    },
    "include": ["src/**/*", "src/**/*.test.ts", "src/**/*.spec.ts", "setup-jest.ts"],
    "exclude": ["node_modules", "dist"]
}
