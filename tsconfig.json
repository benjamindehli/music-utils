{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "outDir": "dist"
    },
    "include": ["src/**/*", "src/**/*.test.ts", "src/**/*.spec.ts", "setup-jest.ts"],
    "exclude": ["node_modules", "dist"]
}
