{
    "version": "3.0.0",
    "name": "@benjamindehli/music-utils",
    "description": "Detect chord names from MIDI note input",
    "keywords": [
        "javascript",
        "midi"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./classes/Chord": {
            "import": "./dist/classes/Chord.js",
            "require": "./dist/classes/Chord.cjs"
        },
        "./classes/ChordType": {
            "import": "./dist/classes/ChordType.js",
            "require": "./dist/classes/ChordType.cjs"
        },
        "./classes/Interval": {
            "import": "./dist/classes/Interval.js",
            "require": "./dist/classes/Interval.cjs"
        },
        "./classes/Midi": {
            "import": "./dist/classes/Midi.js",
            "require": "./dist/classes/Midi.cjs"
        },
        "./classes/Note": {
            "import": "./dist/classes/Note.js",
            "require": "./dist/classes/Note.cjs"
        },
        "./classes/NoteSelection": {
            "import": "./dist/classes/NoteSelection.js",
            "require": "./dist/classes/NoteSelection.cjs"
        },
        "./classes/Scale": {
            "import": "./dist/classes/Scale.js",
            "require": "./dist/classes/Scale.cjs"
        },
        "./classes/ScaleType": {
            "import": "./dist/classes/ScaleType.js",
            "require": "./dist/classes/ScaleType.cjs"
        },
        "./classes/SelectionType": {
            "import": "./dist/classes/SelectionType.js",
            "require": "./dist/classes/SelectionType.cjs"
        },
        "./data/chordTypes": {
            "import": "./dist/data/chordTypes.js",
            "require": "./dist/data/chordTypes.cjs"
        },
        "./data/intervals": {
            "import": "./dist/data/intervals.js",
            "require": "./dist/data/intervals.cjs"
        },
        "./data/notes": {
            "import": "./dist/data/notes.js",
            "require": "./dist/data/notes.cjs"
        },
        "./data/scaleTypes": {
            "import": "./dist/data/scaleTypes.js",
            "require": "./dist/data/scaleTypes.cjs"
        },
        "./data/selectionTypes": {
            "import": "./dist/data/selectionTypes.js",
            "require": "./dist/data/selectionTypes.cjs"
        },
        "./helpers/matchHelpers": {
            "import": "./dist/helpers/matchHelpers.js",
            "require": "./dist/helpers/matchHelpers.cjs"
        },
        "./helpers/noteHelpers": {
            "import": "./dist/helpers/noteHelpers.js",
            "require": "./dist/helpers/noteHelpers.cjs"
        }
    },
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "test": "jest",
        "knip": "knip"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/benjamindehli/music-utils.git"
    },
    "author": "Benjamin Dehli",
    "bugs": {
        "url": "https://github.com/benjamindehli/music-utils/issues"
    },
    "funding": [
        "https://ko-fi.com/benjamindehli",
        "https://store.dehlimusikk.no/coffee"
    ],
    "homepage": "https://github.com/benjamindehli/music-utils#readme",
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-typescript": "^7.28.5",
        "@eslint/js": "^10.0.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.5.0",
        "@typescript-eslint/parser": "^8.57.1",
        "babel-jest": "^30.3.0",
        "eslint": "^10.1.0",
        "globals": "^17.4.0",
        "jest": "^30.3.0",
        "jest-util": "^30.3.0",
        "knip": "^6.0.2",
        "ts-node": "^10.9.2",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "packageManager": "yarn@4.5.0"
}
