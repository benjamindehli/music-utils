        "https://store.dehlimusikk.no/coffee"
    ],
    "homepage": "https://github.com/benjamindehli/music-utils#readme",
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-typescript": "^7.28.5",
        "@eslint/js": "^10.0.1",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.5.0",
        "@typescript-eslint/parser": "^8.57.0",
        "babel-jest": "^30.3.0",
        "eslint": "^10.0.3",
        "globals": "^17.4.0",
        "jest": "^30.3.0",
        "jest-util": "^30.3.0",
        "knip": "^5.86.0",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
